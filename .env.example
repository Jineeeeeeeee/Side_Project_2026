# ── API ──────────────────────────────────────────────────────────
GEMINI_API_KEY=AIza...
FALLBACK_KEY_1=                  # optional: key dự phòng 1
FALLBACK_KEY_2=                  # optional: key dự phòng 2
KEY_ROTATE_THRESHOLD=3           # lỗi liên tiếp trước khi rotate
GEMINI_MODEL=gemini-2.0-flash-exp

# ── Pipeline ─────────────────────────────────────────────────────
MAX_RETRIES=5
SUCCESS_SLEEP=30
RATE_LIMIT_SLEEP=60
MIN_CHARS_PER_CHAPTER=500

# ── 3-Call Architecture ───────────────────────────────────────────
USE_THREE_CALL=true              # false = dùng flow cũ 1-call
PRE_CALL_SLEEP=5                 # sleep (giây) giữa Pre → Trans
POST_CALL_SLEEP=5                # sleep (giây) giữa Trans → Post / giữa retry
POST_CALL_MAX_RETRIES=2          # số lần retry Trans-call khi Post báo lỗi dịch thuật
TRANS_RETRY_ON_QUALITY=true      # có retry Trans-call khi Post báo retry_required không

# ── Scout AI ─────────────────────────────────────────────────────
SCOUT_LOOKBACK=10
SCOUT_REFRESH_EVERY=5
ARC_MEMORY_WINDOW=3

# ── Characters ───────────────────────────────────────────────────
ARCHIVE_AFTER_CHAPTERS=60
EMOTION_RESET_CHAPTERS=5

# ── Merge ────────────────────────────────────────────────────────
IMMEDIATE_MERGE=true
AUTO_MERGE_GLOSSARY=false
AUTO_MERGE_CHARACTERS=false
RETRY_FAILED_PASSES=3

# ── Token Budget (0 = tắt) ───────────────────────────────────────
BUDGET_LIMIT=150000

# ── Paths (thường không cần đổi) ─────────────────────────────────
INPUT_DIR=inputs
OUTPUT_DIR=outputs
DATA_DIR=data
LOG_DIR=logs
PROMPTS_DIR=prompts

# ── Bible System (thêm vào .env.example) ─────────────────────────

# Bật Bible System — xây dựng knowledge base từ toàn bộ truyện
BIBLE_MODE=false

# Depth khi scan: quick (chỉ entities) | standard (đầy đủ) | deep (+ verification)
BIBLE_SCAN_DEPTH=standard

# Consolidation sau mỗi N chapters (merge staging → 3 tầng)
BIBLE_SCAN_BATCH=5

# Sleep giữa các chapter khi scan (giây)
BIBLE_SCAN_SLEEP=10

# Chạy cross-reference sau khi scan xong
BIBLE_CROSS_REF=true

# Thư mục lưu Bible data
BIBLE_DIR=data/bible

